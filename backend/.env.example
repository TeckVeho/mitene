# E-learning バックエンド 環境変数サンプル
# このファイルを .env にコピーして実際の値を設定してください。
# cp .env.example .env

# ----------------------------------------------------------------
# AWS S3 設定（S3_BUCKET_NAME を設定すると S3 モードで動作）
# ----------------------------------------------------------------
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=elearning-files-prod
# EC2 IAM ロールを使用する場合は AWS_ACCESS_KEY_ID / SECRET は不要
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ----------------------------------------------------------------
# GCS（Terraform enable_gcs 時は Cloud Run に GCS_BUCKET / GCP_PROJECT_ID が注入される）
# 優先順位: GCS_BUCKET あり → gcs、次に S3 設定 → s3、それ以外はローカル
# ----------------------------------------------------------------
# GCS_BUCKET=your-project-mitene-uploads-dev
# GCP_PROJECT_ID=your-gcp-project-id
# STORAGE_BACKEND=   # 空で自動。gcs | s3 | local で強制

# ----------------------------------------------------------------
# RDS / MySQL 設定（DATABASE_URL を設定すると MySQL モードで動作）
# 未設定の場合はインメモリモードで動作（開発用）
# ----------------------------------------------------------------
DATABASE_URL=mysql://elearning:password@your-rds-endpoint.ap-northeast-1.rds.amazonaws.com:3306/elearning

# ----------------------------------------------------------------
# Wiki Git リポジトリ設定
# ----------------------------------------------------------------
WIKI_GIT_REPO_URL=https://github.com/your-org/wiki.git
# private repo 用 token（任意）:
# - GitHub PAT: 既定 username は x-access-token
# - GitLab PAT: WIKI_GIT_HTTP_USERNAME=oauth2 を設定
WIKI_GIT_TOKEN=
WIKI_GIT_HTTP_USERNAME=x-access-token
WIKI_GIT_LOCAL_PATH=./wiki-repo
WIKI_GIT_BRANCH=main
# WikiサイトのURL（動画詳細ページで元記事へのリンク表示に使用）
# 例: https://github.com/your-org/wiki/blob/main
WIKI_BASE_URL=https://github.com/your-org/wiki/blob/main

# ----------------------------------------------------------------
# Slack 通知設定
# SLACK_MOCK=true の場合はログ出力のみ（モック動作）
# ----------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_MOCK=true

# ----------------------------------------------------------------
# GitHub OAuth（ログイン認証）
# GitHub Developer Settings で OAuth App を作成し、Client ID / Secret を設定
# https://github.com/settings/developers
# ----------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# フロントエンドのURL（OAuth コールバック後のリダイレクト先）
FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------------
# 管理者（カンマ区切りのメールアドレス、大文字小文字は区別しない）
# 未設定または空の場合、誰も管理画面・管理 API・NotebookLM 連携 API を利用できません
# ----------------------------------------------------------------
ADMIN_EMAILS=admin@example.com

# ----------------------------------------------------------------
# アプリケーション設定
# ----------------------------------------------------------------
# 外部 API 認証キー（カンマ区切りで複数可）
NOTEVIDEO_API_KEYS=your-api-key-here

# フロントエンドオリジン（本番ドメインに変更）
CORS_ALLOWED_ORIGINS=https://your-domain.com

# アプリのベースURL（Slack通知リンクに使用）
APP_BASE_URL=https://your-domain.com

# API のベースURL
API_BASE_URL=https://your-domain.com

PORT=8000
# LOG_LEVEL=INFO
PYTHON_INTERPRETER=/home/deploy/.venv/bin/python

# ----------------------------------------------------------------
# NotebookLM（Playwright セッション）
# ローカル開発: 未設定時は ~/.notebooklm/storage_state.json
# Cloud Run + Terraform enable_gcs: GCS_BUCKET 設定時は自動で GCS と同期
#   gs://<GCS_BUCKET>/notebooklm/storage_state.json（ローカル既定は /tmp/.notebooklm/...）
# NOTEBOOKLM_STORAGE_STATE=   # 任意。上書きしたいパスのみ
# NOTEBOOKLM_GCS_OBJECT_KEY=notebooklm/storage_state.json
# NOTEBOOKLM_DISABLE_GCS_SYNC=true   # GCS 同期を止める
# NOTEBOOKLM_FORCE_GCS_SYNC=true     # Cloud Run 以外（例: GKE）で同期を有効化
