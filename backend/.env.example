# NoteVideo バックエンド 環境変数サンプル
# このファイルを .env にコピーして実際の値を設定してください。
# cp .env.example .env

# ----------------------------------------------------------------
# AWS S3 設定（S3_BUCKET_NAME を設定すると S3 モードで動作）
# ----------------------------------------------------------------
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=notevideo-files-prod
# EC2 IAM ロールを使用する場合は AWS_ACCESS_KEY_ID / SECRET は不要
# ローカル開発時やロールなしの環境では以下を設定
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ----------------------------------------------------------------
# RDS / MySQL 設定（DATABASE_URL を設定すると MySQL モードで動作）
# ----------------------------------------------------------------
DATABASE_URL=mysql://notevideo:password@your-rds-endpoint.ap-northeast-1.rds.amazonaws.com:3306/notevideo

# ----------------------------------------------------------------
# Google Gemini AI 設定（音声生成機能で使用）
# Google AI Studio から取得: https://aistudio.google.com/app/apikey
# ----------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# ----------------------------------------------------------------
# アプリケーション設定
# ----------------------------------------------------------------
# 外部 API 認証キー（カンマ区切りで複数可）
NOTEVIDEO_API_KEYS=your-api-key-here

# フロントエンドオリジン（本番ドメインに変更）
CORS_ALLOWED_ORIGINS=https://your-domain.com

PORT=8000
PYTHON_INTERPRETER=/home/deploy/.venv/bin/python